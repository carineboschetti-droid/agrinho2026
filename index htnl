    def iniciar_jogo():
    print("--- O DESTINO DA FAZENDA ---")
    print("As dívidas estão acumulando e a colheita deste ano foi fraca.")
    print("Se você não aumentar a produção urgentemente, o banco tomará suas terras.")
    print("Uma grande empresa do agronegócio fez uma oferta para comprar a propriedade.")
    
    # A escolha crucial do jogo
    escolha1 = input("Você prefere CONTINUAR com a fazenda ou VENDER? ").strip().lower()

    if escolha1 == "continuar":
        fase_continuar()
    elif escolha1 == "vender":
        fase_vender()
    else:
        print("Opção inválida! A hesitação fez o tempo passar e o banco confiscou as terras.")
        jogar_novamente()

def fase_continuar():
    print("\nVocê decide lutar pelas suas terras! Para aumentar a produção rápido, você precisa de recursos.")
    print("Um banco local oferece um empréstimo de risco, ou você pode tentar uma técnica de plantio cooperativo com vizinhos.")
    
    escolha2 = input("Você prefere pedir o EMPRÉSTIMO ou fazer a COOPERATIVA? ").strip().lower()
    
    if escolha2 == "cooperativa":
        print("\nUnindo forças com os vizinhos, vocês economizam em maquinário e a produção dobra!")
        print("A fazenda foi salva e prosperou de forma sustentável. Você VENCEU!")
    elif escolha2 == "emprestimo":
        print("\nOs juros do empréstimo eram abusivos e uma praga inesperada destruiu a nova plantação.")
        print("Sem dinheiro para pagar o banco, a fazenda foi levada. FIM DE JOGO.")
    else:
        print("Você não tomou uma decisão a tempo. FIM DE JOGO.")
    jogar_novamente()

def fase_vender():
    print("\nVocê decide aceitar a proposta e vender a fazenda para evitar a falência total.")
    print("Com o dinheiro na mão, você pode se aposentar na cidade ou investir em um novo negócio de tecnologia agrícola.")
    
    escolha2 = input("Você prefere ir para a CIDADE ou INVESTIR? ").strip().lower()
    
    if escolha2 == "investir":
        print("\nSeu novo negócio de consultoria agrícola se torna um sucesso absoluto!")
        print("Você ficou rica e agora ajuda outros pequenos fazendeiros a não perderem suas terras. Você VENCEU!")
    elif escolha2 == "cidade":
        print("\nA vida na cidade é cara e você sente falta da rotina no campo. O dinheiro acabou rápido.")
        print("Você garantiu o sustento, mas o arrependimento te acompanha. FIM DE JOGO.")
    else:
        print("Comando inválido. As negociações falharam. FIM DE JOGO.")
    jogar_novamente()

def jogar_novamente():
    resposta = input("\nDeseja jogar novamente? (SIM ou NAO): ").strip().lower()
    if resposta == "sim":
        iniciar_jogo()
    else:
        print("Obrigado por jogar!").

# Inicia o jogo da fazendeira
iniciar_jogo()
